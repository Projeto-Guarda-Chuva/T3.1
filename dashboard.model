<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AUDIO MONITOR</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Bebas+Neue&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --bg: #040a06;
            --bg2: #071210;
            --panel: #0b1e1a;
            --border: #1a3a30;
            --accent: #00ff88;
            --accent-dim: #00c46a;
            --accent-glow: rgba(0, 255, 136, 0.15);
            --accent-glow-strong: rgba(0, 255, 136, 0.35);
            --danger: #ff4040;
            --warn: #ffaa00;
            --muted: #2a4a3e;
            --text: #c8ffe8;
            --text-dim: #5a8a74;
            --mono: 'Share Tech Mono', monospace;
            --display: 'Bebas Neue', sans-serif;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: var(--bg);
            color: var(--text);
            font-family: var(--mono);
            min-height: 100vh;
            overflow-x: hidden;
            background-image:
                radial-gradient(ellipse 80% 60% at 50% -10%, rgba(0,255,136,0.06) 0%, transparent 70%),
                repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,255,136,0.025) 40px),
                repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,255,136,0.015) 40px);
        }

        /* Scanline overlay */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background: repeating-linear-gradient(
                0deg,
                transparent,
                transparent 2px,
                rgba(0,0,0,0.08) 2px,
                rgba(0,0,0,0.08) 4px
            );
            pointer-events: none;
            z-index: 999;
        }

        header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 20px 32px 16px;
            border-bottom: 1px solid var(--border);
            background: rgba(0,0,0,0.3);
        }

        .header-left {
            display: flex;
            align-items: baseline;
            gap: 16px;
        }

        .logo {
            font-family: var(--display);
            font-size: 2rem;
            letter-spacing: 0.12em;
            color: var(--accent);
            text-shadow: 0 0 20px var(--accent-glow-strong), 0 0 60px rgba(0,255,136,0.1);
        }

        .logo-sub {
            font-size: 0.7rem;
            color: var(--text-dim);
            letter-spacing: 0.25em;
            text-transform: uppercase;
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 24px;
        }

        .live-badge {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 0.65rem;
            letter-spacing: 0.2em;
            color: var(--accent);
            padding: 5px 12px;
            border: 1px solid var(--accent);
            border-radius: 2px;
            background: var(--accent-glow);
        }

        .live-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--accent);
            animation: pulse-dot 1.2s ease-in-out infinite;
            box-shadow: 0 0 6px var(--accent);
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.4; transform: scale(0.7); }
        }

        .clock {
            font-size: 0.75rem;
            color: var(--text-dim);
            letter-spacing: 0.1em;
        }

        /* Main layout */
        main {
            padding: 24px 32px;
            display: grid;
            grid-template-rows: auto auto auto;
            gap: 20px;
        }

        /* ── WAVEFORM PANEL ── */
        .waveform-panel {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 20px;
            position: relative;
            overflow: hidden;
        }

        .waveform-panel::before {
            content: '';
            position: absolute;
            inset: 0;
            background: radial-gradient(ellipse 60% 80% at 50% 50%, rgba(0,255,136,0.03), transparent);
            pointer-events: none;
        }

        .panel-label {
            font-size: 0.6rem;
            letter-spacing: 0.3em;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-bottom: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .panel-label::after {
            content: '';
            flex: 1;
            height: 1px;
            background: var(--border);
        }

        .waveform-container {
            position: relative;
            height: 200px;
        }

        /* Horizontal center line */
        .waveform-container::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 0; right: 0;
            height: 1px;
            background: var(--muted);
            opacity: 0.5;
            pointer-events: none;
            z-index: 1;
        }

        #waveformChart { position: relative; z-index: 2; }

        /* ── STATS ROW ── */
        .stats-row {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 14px;
        }

        .stat-card {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 16px 18px;
            position: relative;
            transition: border-color 0.3s, box-shadow 0.3s;
        }

        .stat-card:hover {
            border-color: var(--accent-dim);
            box-shadow: 0 0 16px var(--accent-glow);
        }

        .stat-card.alert {
            border-color: var(--danger);
            box-shadow: 0 0 16px rgba(255,64,64,0.2);
            animation: alert-pulse 1.5s ease-in-out infinite;
        }

        @keyframes alert-pulse {
            0%, 100% { box-shadow: 0 0 16px rgba(255,64,64,0.2); }
            50% { box-shadow: 0 0 28px rgba(255,64,64,0.4); }
        }

        .stat-label {
            font-size: 0.55rem;
            letter-spacing: 0.25em;
            color: var(--text-dim);
            text-transform: uppercase;
            margin-bottom: 8px;
        }

        .stat-value {
            font-family: var(--display);
            font-size: 2.2rem;
            letter-spacing: 0.05em;
            color: var(--accent);
            line-height: 1;
            text-shadow: 0 0 16px var(--accent-glow-strong);
            transition: color 0.3s;
        }

        .stat-card.alert .stat-value { color: var(--danger); text-shadow: 0 0 16px rgba(255,64,64,0.5); }

        .stat-unit {
            font-size: 0.6rem;
            color: var(--text-dim);
            margin-top: 4px;
        }

        /* ── BOTTOM ROW: History + Command ── */
        .bottom-row {
            display: grid;
            grid-template-columns: 1fr 320px;
            gap: 20px;
        }

        /* History chart */
        .history-panel {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 20px;
        }

        .history-container { height: 150px; }

        /* Command panel */
        .command-panel {
            background: var(--panel);
            border: 1px solid var(--border);
            border-radius: 4px;
            padding: 20px;
            display: flex;
            flex-direction: column;
        }

        .command-display {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .command-value {
            font-family: var(--display);
            font-size: 4.5rem;
            letter-spacing: 0.1em;
            color: var(--accent);
            text-shadow: 0 0 30px var(--accent-glow-strong);
            transition: all 0.3s ease;
            line-height: 1;
        }

        .command-value.none { color: var(--muted); text-shadow: none; font-size: 2rem; letter-spacing: 0.3em; }
        .command-value.unknown { color: var(--warn); text-shadow: 0 0 20px rgba(255,170,0,0.3); }
        .command-value.error { color: var(--danger); font-size: 1.8rem; }

        .command-text-raw {
            font-size: 0.65rem;
            color: var(--text-dim);
            letter-spacing: 0.1em;
            text-align: center;
            min-height: 1.2em;
        }

        .command-ts {
            font-size: 0.6rem;
            color: var(--muted);
            letter-spacing: 0.1em;
        }

        /* Outlier list */
        .outlier-section {
            margin-top: 10px;
            padding-top: 10px;
            border-top: 1px solid var(--border);
        }

        .outlier-list {
            max-height: 60px;
            overflow-y: auto;
            display: flex;
            flex-wrap: wrap;
            gap: 4px;
            margin-top: 8px;
        }

        .outlier-chip {
            font-size: 0.6rem;
            padding: 2px 7px;
            background: rgba(255,64,64,0.12);
            border: 1px solid rgba(255,64,64,0.35);
            border-radius: 2px;
            color: var(--danger);
        }

        .no-outliers {
            font-size: 0.65rem;
            color: var(--text-dim);
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg2); }
        ::-webkit-scrollbar-thumb { background: var(--muted); border-radius: 2px; }

        /* Corner decoration */
        .corner-tl, .corner-br {
            position: absolute;
            width: 14px;
            height: 14px;
            pointer-events: none;
        }
        .corner-tl { top: 6px; left: 6px; border-top: 2px solid var(--accent-dim); border-left: 2px solid var(--accent-dim); }
        .corner-br { bottom: 6px; right: 6px; border-bottom: 2px solid var(--accent-dim); border-right: 2px solid var(--accent-dim); }

        @media (max-width: 900px) {
            .stats-row { grid-template-columns: repeat(3, 1fr); }
            .bottom-row { grid-template-columns: 1fr; }
            main { padding: 16px; }
        }
    </style>
</head>
<body>

<header>
    <div class="header-left">
        <span class="logo">AUDIO MONITOR</span>
        <span class="logo-sub">PT-BR Voice Recognition</span>
    </div>
    <div class="header-right">
        <div class="live-badge"><div class="live-dot"></div> LIVE</div>
        <div class="clock" id="clock">--:--:--</div>
    </div>
</header>

<main>

    <!-- Waveform -->
    <div class="waveform-panel">
        <div class="corner-tl"></div>
        <div class="corner-br"></div>
        <div class="panel-label">Waveform · Real-time PCM</div>
        <div class="waveform-container">
            <canvas id="waveformChart"></canvas>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card" id="card-current">
            <div class="stat-label">Current RMS</div>
            <div class="stat-value" id="stat-current">—</div>
            <div class="stat-unit">amplitude</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Average RMS</div>
            <div class="stat-value" id="stat-avg">—</div>
            <div class="stat-unit">last 5 min</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Peak RMS</div>
            <div class="stat-value" id="stat-max">—</div>
            <div class="stat-unit">maximum</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Std Dev</div>
            <div class="stat-value" id="stat-std">—</div>
            <div class="stat-unit">variance</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Samples</div>
            <div class="stat-value" id="stat-samples">—</div>
            <div class="stat-unit">in history</div>
        </div>
    </div>

    <!-- Bottom row -->
    <div class="bottom-row">

        <!-- Noise history + outliers -->
        <div class="history-panel">
            <div class="panel-label">RMS History · 5-minute window</div>
            <div class="history-container">
                <canvas id="historyChart"></canvas>
            </div>
            <div class="outlier-section">
                <div class="panel-label" style="margin-bottom:6px;">Outliers <span style="color:var(--accent)" id="outlier-count">(0)</span></div>
                <div class="outlier-list" id="outlier-list">
                    <span class="no-outliers">No outliers detected</span>
                </div>
            </div>
        </div>

        <!-- Voice command -->
        <div class="command-panel">
            <div class="panel-label">Voice Command · Vosk PT-BR</div>
            <div class="command-display">
                <div class="command-value none" id="cmd-value">AGUARDANDO</div>
                <div class="command-text-raw" id="cmd-text"></div>
                <div class="command-ts" id="cmd-ts">—</div>
            </div>
        </div>

    </div>
</main>

<script>
    // ── Clock ──
    function updateClock() {
        const now = new Date();
        document.getElementById('clock').textContent = now.toTimeString().slice(0,8);
    }
    setInterval(updateClock, 1000);
    updateClock();

    // ── Waveform Chart ──
    const waveCtx = document.getElementById('waveformChart').getContext('2d');
    const waveChart = new Chart(waveCtx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [{
                data: [],
                borderColor: 'rgba(0,255,136,0.85)',
                borderWidth: 1.2,
                pointRadius: 0,
                fill: true,
                backgroundColor: (ctx) => {
                    const g = ctx.chart.ctx.createLinearGradient(0, 0, 0, 200);
                    g.addColorStop(0, 'rgba(0,255,136,0.08)');
                    g.addColorStop(0.5, 'rgba(0,255,136,0.03)');
                    g.addColorStop(1, 'rgba(0,255,136,0.08)');
                    return g;
                },
                tension: 0.15
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            scales: {
                y: {
                    min: -32768, max: 32767,
                    grid: { color: 'rgba(26,58,48,0.5)', lineWidth: 1 },
                    ticks: { color: '#2a4a3e', font: { family: "'Share Tech Mono'", size: 9 }, maxTicksLimit: 5 }
                },
                x: { display: false }
            },
            plugins: { legend: { display: false }, tooltip: { enabled: false } }
        }
    });

    // ── History Chart ──
    const histCtx = document.getElementById('historyChart').getContext('2d');
    const histChart = new Chart(histCtx, {
        type: 'line',
        data: {
            labels: [],
            datasets: [
                {
                    label: 'RMS',
                    data: [],
                    borderColor: 'rgba(0,196,106,0.9)',
                    borderWidth: 1.5,
                    pointRadius: 0,
                    fill: true,
                    backgroundColor: 'rgba(0,196,106,0.07)',
                    tension: 0.3
                },
                {
                    label: 'Threshold',
                    data: [],
                    borderColor: 'rgba(255,64,64,0.5)',
                    borderWidth: 1,
                    borderDash: [4, 3],
                    pointRadius: 0,
                    fill: false,
                    tension: 0
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            animation: false,
            scales: {
                y: {
                    min: 0,
                    grid: { color: 'rgba(26,58,48,0.5)' },
                    ticks: { color: '#2a4a3e', font: { family: "'Share Tech Mono'", size: 9 }, maxTicksLimit: 4 }
                },
                x: { display: false }
            },
            plugins: {
                legend: { display: false },
                tooltip: { enabled: false }
            }
        }
    });

    // ── Fetch Waveform ──
    async function fetchWaveform() {
        try {
            const r = await fetch('/waveform');
            if (!r.ok) return;
            const d = await r.json();
            if (d.waveform && d.waveform.length) {
                const pts = d.waveform.length;
                waveChart.data.labels = Array.from({length: pts}, (_, i) => i);
                waveChart.data.datasets[0].data = d.waveform;
                waveChart.update('none');
            }
        } catch {}
    }

    // ── Fetch Noise Stats ──
    async function fetchNoise() {
        try {
            const r = await fetch('/noise');
            if (!r.ok) return;
            const d = await r.json();

            const fmt = v => v >= 1000 ? (v/1000).toFixed(1)+'k' : Math.round(v);

            document.getElementById('stat-current').textContent = fmt(d.current_rms);
            document.getElementById('stat-avg').textContent = fmt(d.average_rms);
            document.getElementById('stat-max').textContent = fmt(d.max_rms);
            document.getElementById('stat-std').textContent = fmt(d.std_dev);
            document.getElementById('stat-samples').textContent = d.samples_count;

            // Alert if current is above threshold
            const card = document.getElementById('card-current');
            card.classList.toggle('alert', d.current_rms > d.outlier_threshold);

            // Outliers
            const list = document.getElementById('outlier-list');
            document.getElementById('outlier-count').textContent = `(${d.outliers.length})`;
            if (d.outliers.length === 0) {
                list.innerHTML = '<span class="no-outliers">No outliers detected</span>';
            } else {
                list.innerHTML = d.outliers.slice(-20).map(o => {
                    const t = new Date(o.timestamp * 1000).toTimeString().slice(0,8);
                    return `<span class="outlier-chip">${t} · ${Math.round(o.rms)}</span>`;
                }).join('');
            }

            // History chart — reconstruct from /noise history isn't available directly,
            // so we append the latest point to the chart data
            const ts = new Date(Date.now()).toTimeString().slice(0,8);
            if (histChart.data.labels.length > 300) {
                histChart.data.labels.shift();
                histChart.data.datasets[0].data.shift();
                histChart.data.datasets[1].data.shift();
            }
            histChart.data.labels.push(ts);
            histChart.data.datasets[0].data.push(d.current_rms);
            histChart.data.datasets[1].data.push(d.outlier_threshold);
            histChart.update('none');

        } catch {}
    }

    // ── Fetch Command ──
    async function fetchCommand() {
        try {
            const r = await fetch('/command');
            if (!r.ok) return;
            const d = await r.json();

            const el = document.getElementById('cmd-value');
            const cmd = d.command || 'NONE';

            el.className = 'command-value';
            if (cmd === 'NONE') {
                el.classList.add('none');
                el.textContent = 'AGUARDANDO';
            } else if (cmd === 'UNKNOWN') {
                el.classList.add('unknown');
                el.textContent = cmd;
            } else if (d.error) {
                el.classList.add('error');
                el.textContent = 'ERRO';
            } else {
                el.textContent = cmd;
            }

            document.getElementById('cmd-text').textContent = d.text ? `"${d.text}"` : '';
            document.getElementById('cmd-ts').textContent = new Date().toTimeString().slice(0,8);
        } catch {}
    }

    const POLL = {{ poll_interval * 1000 }};

    setInterval(fetchWaveform, POLL);
    setInterval(fetchNoise, POLL);
    setInterval(fetchCommand, POLL * 3); // command is heavier, poll less

    fetchWaveform();
    fetchNoise();
    fetchCommand();
</script>
</body>
</html>
